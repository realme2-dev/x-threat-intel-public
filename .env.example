# ─── 크롤링 대상 ─────────────────────────────────────────────────────────────
# 쉼표로 구분. 비워두면 x_crawler.py 기본값 사용
TARGET_ACCOUNTS=HalcyonAi,DarkWebInformer,MonThreat

# ─── 테스트 설정 (test_crawl.py) ─────────────────────────────────────────────
TEST_ACCOUNT=DarkWebInformer
SKIP_PLAYWRIGHT=false

# ─── 검색 모드 ────────────────────────────────────────────────────────────────
# user: 특정 계정 타임라인 수집
# term: 검색어로 트윗 검색
# hashtag: 해시태그 검색
SEARCH_MODE=user
MAX_TWEETS=5

# ─── 스케줄링 ─────────────────────────────────────────────────────────────────
SCHEDULE_INTERVAL_HOURS=12

# ─── 재시도 / Anti-bot ────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=5
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0

# ─── 저장 경로 ────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
LOG_DIR=/app/logs

# ─── 로깅 ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Nitter 인스턴스 헬스체크 타임아웃(초) ────────────────────────────────────
INSTANCE_HEALTH_TIMEOUT=5

# ─── Playwright 대기 시간(초) ─────────────────────────────────────────────────
PLAYWRIGHT_WAIT_SEC=8

# ─── LLM 분석 설정 ───────────────────────────────────────────────────────────
# 사용할 백엔드: gemini | openai | grok (기본값: gemini)
LLM_BACKEND=gemini

# Gemini (무료) - https://aistudio.google.com/apikey
# 권장 모델: gemini-3.1-flash-lite-preview (RPD 1000, TPM 250K - 무료 최다한도)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# OpenAI (유료) - https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Grok (무료 티어) - https://console.x.ai/
GROK_API_KEY=
GROK_MODEL=grok-3-mini-fast-beta

# LLM 응답 타임아웃(초)
LLM_TIMEOUT=60

# ─── 레거시 (구 analyze.py용 - 무시해도 됨) ──────────────────────────────────
GH_TOKEN=
GITHUB_REPOSITORY=
TARGETS=DDoS Korea,RipperSec

# ─── Telegram 알림 설정 ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
